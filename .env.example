# Application Settings
NODE_ENV=development
PORT=5000
APP_URL=http://localhost:3000
CLIENT_URL=http://localhost:3000

# MongoDB Configuration
# NOTE: Requires a replica set for transactions to work
MONGODB_URI=mongodb://admin:password@localhost:27017/unheard_india?authSource=admin&replicaSet=rs0

# Redis Configuration
REDIS_URL=redis://localhost:6379

# JWT RS256 Keys (Generate using `npm run generate-keys` or `npx ts-node scripts/generate-keys.ts`)
RS256_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
RS256_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# Email Delivery (Resend/SendGrid/SMTP)
EMAIL_FROM=noreply@university.edu
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=mockuser
SMTP_PASS=mockpass

# Fallback secrets for local development
JWT_SECRET=dummy_local_secret_key_change_in_production
SESSION_SECRET=super_secret_for_express_session
